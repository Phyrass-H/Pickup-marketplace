# =====================================================================
# PickUp — environment template. Copy to .env.local and fill in real values.
#   cp .env.example .env.local
# .env.local is git-ignored. NEVER commit real keys.
# Values live in: Supabase dashboard -> Project Settings -> API / API Keys.
# =====================================================================

# Bare project URL (no /rest/v1/ suffix), e.g. https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Browser-safe key: "anon" (legacy JWT) or "publishable" (sb_publishable_...).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key: "service_role" (legacy JWT) or "secret" (sb_secret_...).
# BYPASSES RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------
# NOT an env var, but required for magic-link sign-in to work:
# In the Supabase dashboard -> Authentication -> URL Configuration, add every
# origin's /auth/callback to the Redirect URLs allowlist (and set Site URL):
#   http://localhost:3000/auth/callback     (local dev)
#   https://<your-prod-domain>/auth/callback (production)
#   https://*-<team>.vercel.app/auth/callback (Vercel preview, if used)
# Without this, magic links redirect to the Site URL and sign-in silently fails.
# ---------------------------------------------------------------------
